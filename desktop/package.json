{
  "name": "haifa-hivemind-desktop",
  "version": "0.1.1",
  "description": "Haifa HiveMind — local private research AI by Haifa Intelligence",
  "author": "Haifa Intelligence",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "HIVEMIND_DEV=1 electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ai.haifa.hivemind",
    "productName": "Haifa HiveMind",
    "directories": { "output": "release", "buildResources": "build" },
    "files": ["main.js", "preload.js", "splash.html"],
    "extraResources": [
      { "from": "../frontend/dist", "to": "web" },
      { "from": "../backend", "to": "backend", "filter": ["**/*", "!data/**", "!.venv/**", "!__pycache__/**", "!build/**"] }
    ],
    "win": { "target": ["nsis"], "icon": "build/icon.ico" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "license": "build/eula.txt"
    },
    "linux": { "target": ["AppImage"], "icon": "build/icon.png", "category": "Science" }
  }
}
